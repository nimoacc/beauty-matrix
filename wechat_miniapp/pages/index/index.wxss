/* 颜值矩阵分析 — 首页样式 */

/* 顶部标题区 */
.hero {
  padding: 60rpx 40rpx 30rpx;
  text-align: center;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #e94560, #ff8c42, #ffd700);
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 4rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: #6666aa;
  margin-top: 12rpx;
  letter-spacing: 8rpx;
}

/* 偏好选择器 */
.pref-bar {
  margin: 0 30rpx 20rpx;
  padding: 20rpx 28rpx;
  background: rgba(233, 69, 96, 0.08);
  border: 1px solid rgba(233, 69, 96, 0.2);
  border-radius: 16rpx;
}

.pref-icon { font-size: 28rpx; }
.pref-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #e94560;
}
.arrow { font-size: 36rpx; color: #6666aa; }

/* 偏好选择弹层 */
.pref-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.pref-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.pref-modal-content {
  width: 100%;
  background: #141430;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx 60rpx;
  max-height: 70vh;
}

.pref-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.pref-modal-sub {
  font-size: 24rpx;
  color: #6666aa;
  margin-bottom: 24rpx;
}

.pref-scroll { max-height: 400rpx; }

.pref-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: #aaaacc;
  background: rgba(255,255,255,0.03);
}

.pref-item.active {
  color: #e94560;
  background: rgba(233,69,96,0.12);
  font-weight: 600;
}

.check { color: #e94560; font-size: 32rpx; }

.pref-modal-close {
  text-align: center;
  padding: 24rpx;
  color: #6666aa;
  font-size: 26rpx;
  margin-top: 16rpx;
}

/* 图片区域 */
.image-zone {
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.03);
  border: 2rpx dashed #2a2a4e;
  min-height: 500rpx;
  position: relative;
}

.image-zone.has-image {
  border-color: rgba(233,69,96,0.2);
  border-style: solid;
}

.preview-image {
  width: 100%;
  height: 500rpx;
}

.image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 500rpx;
  gap: 20rpx;
}

.placeholder-icon { font-size: 80rpx; opacity: 0.6; }
.placeholder-text { font-size: 30rpx; color: #8888aa; }
.placeholder-hint { margin-top: 8rpx; }

.rechoose-btn {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 操作区 */
.action-bar {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-bar .btn-primary {
  width: 100%;
  text-align: center;
}

.options-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 16rpx;
}

.option-item {
  padding: 8rpx 0;
}

/* 底部 */
.footer-note {
  text-align: center;
  padding: 40rpx;
}
