/* 颜值矩阵分析 — 结果页样式 */

/* 分数卡片 */
.score-card {
  text-align: center;
  padding: 50rpx 30rpx;
}

.score-ring {
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto 30rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(233,69,96,0.15), rgba(255,140,66,0.15));
  border: 6rpx solid rgba(233,69,96,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-ring.S { border-color: #ff2d55; }
.score-ring.A { border-color: #ff6b35; }
.score-ring.B { border-color: #ffb800; }
.score-ring.C { border-color: #4ecdc4; }

.score-number {
  font-size: 72rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
}

.score-total {
  font-size: 24rpx;
  color: #6666aa;
  margin-top: 4rpx;
}

.score-grade {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.grade-text { font-size: 28rpx; color: #aaaacc; }
.grade-value { font-size: 36rpx; }

.grade-label {
  font-size: 32rpx;
  color: #ffd700;
  font-weight: 600;
}

/* 化妆面板 */
.makeup-panel {
  margin-top: 20rpx;
}

.makeup-result {
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(233,69,96,0.06);
  border-radius: 16rpx;
}

/* 特征行 */
.feature-row {
  margin-bottom: 24rpx;
}

/* 公式 */
.formula-panel { margin-top: 16rpx; }

.formula-text {
  display: block;
  color: #aaaacc;
  line-height: 1.6;
  word-break: break-all;
  padding: 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.decomp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.decomp-item {
  text-align: center;
  padding: 16rpx;
  background: rgba(255,255,255,0.03);
  border-radius: 12rpx;
}

.decomp-item .text-md {
  display: block;
  margin-top: 8rpx;
}

/* 偏好对比 */
.pref-compare-list {
  margin-top: 16rpx;
}

.pref-compare-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
}

.pref-compare-item.highlight {
  background: rgba(233,69,96,0.08);
  margin: 0 -20rpx;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
}

.pref-compare-item > text:first-child {
  width: 120rpx;
  flex-shrink: 0;
  text-align: right;
}

.pref-compare-bar {
  flex: 1;
  height: 10rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 5rpx;
  overflow: hidden;
}

.pref-compare-fill {
  height: 100%;
  background: linear-gradient(90deg, #e94560, #ff8c42);
  border-radius: 5rpx;
  transition: width 0.6s ease;
}

/* 操作行 */
.action-row {
  display: flex;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: 20rpx;
}

.action-row .btn-primary,
.action-row .btn-secondary,
.action-row .btn-ghost {
  flex: 1;
  text-align: center;
}
