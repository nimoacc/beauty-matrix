/* 颜值矩阵分析系统 — 全局样式 */

page {
  background-color: #0a0a1a;
  color: #e0e0f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  height: 100%;
}

/* ===== 通用布局 ===== */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== 卡片 ===== */
.card {
  background: linear-gradient(135deg, #141430, #1a1a3e);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  border: 1px solid rgba(233, 69, 96, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e94560;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* ===== 按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #e94560, #c23152);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn-secondary {
  background: rgba(233, 69, 96, 0.1);
  color: #e94560;
  border: 2rpx solid #e94560;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-ghost {
  background: transparent;
  color: #8888aa;
  border: 2rpx solid #3a3a5e;
  border-radius: 16rpx;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
}

/* ===== 标签/徽章 ===== */
.badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-grade-s { background: #ff2d55; color: #fff; }
.badge-grade-a { background: #ff6b35; color: #fff; }
.badge-grade-b { background: #ffb800; color: #1a1a3e; }
.badge-grade-c { background: #4ecdc4; color: #1a1a3e; }
.badge-grade-d { background: #6c63ff; color: #fff; }

/* ===== 字体层级 ===== */
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 26rpx; }
.text-md { font-size: 30rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 48rpx; }
.text-2xl { font-size: 64rpx; }
.text-3xl { font-size: 80rpx; }

.text-muted { color: #666688; }
.text-accent { color: #e94560; }
.text-gold { color: #ffd700; }
.text-cyan { color: #00d4ff; }

/* ===== 工具类 ===== */
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-col { display: flex; flex-direction: column; }
.gap-sm { gap: 12rpx; }
.gap-md { gap: 24rpx; }
.gap-lg { gap: 36rpx; }
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 32rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 32rpx; }

/* ===== 分割线 ===== */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #3a3a5e, transparent);
  margin: 30rpx 0;
}

/* ===== 进度条 ===== */
.progress-bar {
  height: 12rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

/* ===== 加载动画 ===== */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(233, 69, 96, 0.2);
  border-top-color: #e94560;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: #555577;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}
